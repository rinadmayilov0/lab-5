CSS


body {
    background-color: #e0e0e0;
    margin: 0;
    padding: 0;
}


.sehife {
    position: relative;
    width: 600px;
    height: 400px;
    margin: 100px auto; 
}


.qutu {
    width: 150px;
    height: 150px;
    position: absolute;
}


.yasil {
    background-color: #2e7d32;
    top: 50px;
    left: 50px;
}

.mavi {
    background-color: #0000ff;
    top: 50px;
    left: 220px;
}

.sari {
    background-color: #ffff4d;
    top: 140px;
    left: 120px;
}

.qirmizi {
    background-color: #e53935;
    top: 140px;
    left: 290px;
}

